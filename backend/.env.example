# Runtime
NODE_ENV=development
PORT=4000

# Database (MongoDB Atlas connection string)
MONGO_URL=mongodb+srv://usuario:password@cluster.mongodb.net/gda?retryWrites=true&w=majority

# Auth
JWT_SECRET=change_me_32_chars_minimum________
JWT_EXPIRES_IN=1d
REFRESH_SECRET=change_me_refresh_32_chars________
REFRESH_EXPIRES_IN=7d
SSE_TOKEN_EXPIRES_IN=60s

# CORS
CORS_ORIGINS=http://localhost:5173

# ---------- MQTT (broker en la nube - HiveMQ Cloud) ----------
# Credenciales y host: ver el documento interno del equipo ("GDA Guia Setup").
# NUNCA commitear las credenciales reales.
MQTT_HOST=
MQTT_PORT=8883
MQTT_USER=
MQTT_PASS=
# UNICO POR PERSONA. Si dos backends usan el mismo client ID,
# el broker desconecta a uno cada vez que aparece el otro.
MQTT_CLIENT_ID=backend-tunombre
# Prefijo de topics. En desarrollo usa el tuyo (gda/dev-tunombre);
# gda/prod es SOLO del nodo real y del backend desplegado.
TOPIC_PREFIX=gda/dev-tunombre
# false en local: el backend evalua y loguea pero NO publica comandos de riego.
# Solo true en el backend desplegado.
MODO_ESCRITURA=false

# Motor de riego (defaults globales; cada maceta puede sobreescribirlos)
RAIN_PROB_THRESHOLD=50
HEAT_TEMP_THRESHOLD=35
DEFAULT_IRRIGATION_SEC=5
HEAT_IRRIGATION_SEC=3
SENSOR_TIMEOUT_MIN=15
COMMAND_TIMEOUT_SEC=60
WEATHER_TTL_HOURS=3

# Email de alertas (opcional; si SMTP_HOST queda vacio, las alertas solo se loguean)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=GDA <no-reply@gda.local>
